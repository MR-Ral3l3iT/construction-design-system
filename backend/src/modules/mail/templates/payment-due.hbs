<!DOCTYPE html>
<html lang="th">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1"></head>
<body style="font-family:sans-serif;background:#f5f5f5;margin:0;padding:24px">
  <div style="max-width:520px;margin:0 auto;background:#fff;border-radius:12px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,.08)">
    <div style="background:#1e40af;padding:24px 32px">
      <h1 style="color:#fff;margin:0;font-size:18px">UAT-ARCH System</h1>
    </div>
    <div style="padding:32px">
      <p style="margin:0 0 8px;color:#374151">เรียน คุณ{{customerName}}</p>
      <h2 style="margin:0 0 16px;color:#111827;font-size:20px">แจ้งเตือนครบกำหนดชำระเงิน 🔔</h2>
      <table style="width:100%;border-collapse:collapse;margin-bottom:24px">
        <tr><td style="padding:8px 0;color:#6b7280;width:140px">โครงการ</td><td style="color:#111827;font-weight:600">{{projectName}}</td></tr>
        <tr><td style="padding:8px 0;color:#6b7280">งวด</td><td style="color:#111827;font-weight:600">{{milestoneTitle}}</td></tr>
        <tr><td style="padding:8px 0;color:#6b7280">จำนวนเงิน</td><td style="color:#1e40af;font-weight:700;font-size:16px">{{amount}} บาท</td></tr>
        <tr><td style="padding:8px 0;color:#6b7280">กำหนดชำระ</td><td style="color:#dc2626;font-weight:600">{{dueDate}}</td></tr>
      </table>
      <a href="{{appUrl}}" style="display:inline-block;background:#1e40af;color:#fff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:600">ดูรายละเอียด</a>
    </div>
    <div style="padding:16px 32px;background:#f9fafb;border-top:1px solid #e5e7eb">
      <p style="margin:0;font-size:12px;color:#9ca3af">อีเมลนี้ส่งอัตโนมัติจากระบบ UAT-ARCH กรุณาอย่าตอบกลับ</p>
    </div>
  </div>
</body>
</html>
