# ─────────────────────────────────────────
# Database — PostgreSQL
# ─────────────────────────────────────────
POSTGRES_DB=construction_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_this_password
POSTGRES_PORT=5432

# Prisma connection URL (ใช้ใน backend)
DATABASE_URL=postgresql://postgres:change_this_password@localhost:5432/construction_db

# ─────────────────────────────────────────
# Storage — MinIO
# ─────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_this_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=localhost
MINIO_BUCKET=construction-files
MINIO_USE_SSL=false

# ─────────────────────────────────────────
# Backend — NestJS
# ─────────────────────────────────────────
BACKEND_PORT=3001
NODE_ENV=development

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS — domain ที่อนุญาต (คั่นด้วย comma)
CORS_ORIGINS=http://localhost:3000

# Upload limits
MAX_FILE_SIZE_MB=50

# ─────────────────────────────────────────
# Frontend — Next.js
# ─────────────────────────────────────────
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_NAME=Construction Design System
