# ─────────────────────────────────────────────────────────────────────────────
# Construction Design System — Production Environment Template
# Copy to .env.production and fill in real values before deploying.
# NEVER commit the filled .env.production to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────
# Database — PostgreSQL
# ─────────────────────────────────────────
POSTGRES_DB=construction_db
POSTGRES_USER=cds_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# Constructed automatically by docker-compose; set explicitly for direct access
DATABASE_URL=postgresql://cds_user:CHANGE_ME_STRONG_PASSWORD@postgres:5432/construction_db

# ─────────────────────────────────────────
# Storage — MinIO (S3-compatible)
# ─────────────────────────────────────────
MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_STRONG_PASSWORD
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio             # service name inside docker network
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_STRONG_PASSWORD
MINIO_BUCKET=construction-files
MINIO_USE_SSL=false              # set true when using external TLS-terminated MinIO

# ─────────────────────────────────────────
# Backend — NestJS
# ─────────────────────────────────────────
BACKEND_PORT=3004
NODE_ENV=production

# Generate with: openssl rand -hex 64
JWT_SECRET=CHANGE_ME_AT_LEAST_64_CHARS_RANDOM_STRING
JWT_EXPIRES_IN=15m

# Generate with: openssl rand -hex 64
JWT_REFRESH_SECRET=CHANGE_ME_DIFFERENT_64_CHARS_RANDOM_STRING
JWT_REFRESH_EXPIRES_IN=7d

# Comma-separated allowed origins (no trailing slash)
CORS_ORIGINS=https://your-domain.com

MAX_FILE_SIZE_MB=50

# ─────────────────────────────────────────
# Frontend — Next.js
# ─────────────────────────────────────────
FRONTEND_PORT=3003

# URL the browser uses to reach the API (must be publicly reachable)
NEXT_PUBLIC_API_URL=https://your-domain.com/api

NEXT_PUBLIC_APP_NAME=Construction Design System

# ─────────────────────────────────────────
# Nginx
# ─────────────────────────────────────────
NGINX_PORT=80
NGINX_SSL_PORT=443

# Domain for TLS certificate (Let's Encrypt)
DOMAIN=your-domain.com
LETSENCRYPT_EMAIL=admin@your-domain.com
